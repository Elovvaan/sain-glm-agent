# SAIN GLM Agent — environment configuration template
# Copy this file to .env and fill in your values.

# ── Primary model provider ──────────────────────────────────────────────────
# Supported values: glm, openai, claude, gemini, deepseek, qwen, local
SAIN_PROVIDER=glm

# ── GLM (ZhipuAI) ────────────────────────────────────────────────────────────
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
SAIN_GLM_MODEL=glm-4-flash
SAIN_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── OpenAI (optional) ────────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_api_key_here
# SAIN_OPENAI_MODEL=gpt-4o

# ── Anthropic Claude (optional) ──────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# SAIN_CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Google Gemini (optional) ─────────────────────────────────────────────────
# GOOGLE_API_KEY=your_google_api_key_here
# SAIN_GEMINI_MODEL=gemini-1.5-pro

# ── DeepSeek (optional) ──────────────────────────────────────────────────────
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# SAIN_DEEPSEEK_MODEL=deepseek-coder

# ── Qwen (optional) ──────────────────────────────────────────────────────────
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# SAIN_QWEN_MODEL=qwen-max

# ── GitHub integration ───────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Agent behaviour ──────────────────────────────────────────────────────────
SAIN_MAX_TOKENS=4096
SAIN_TEMPERATURE=0.1
SAIN_MAX_ITERATIONS=10
SAIN_MEMORY_MAX_MESSAGES=50
SAIN_LOG_LEVEL=INFO
SAIN_LOG_FORMAT=rich
# Optional: absolute path to a log file
# SAIN_LOG_FILE=/var/log/sain-agent/agent.log
